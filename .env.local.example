# Copy this file to .env.local and fill in the two values from your Supabase
# dashboard.
#
#   URL  → Project Settings → Data API → Project URL
#          (or https://<Reference ID>.supabase.co — the ref is the segment in
#          your dashboard address: /dashboard/project/<ref>)
#
#   KEY  → Project Settings → API Keys → "Publishable key" (sb_publishable_…)
#
# The publishable key is designed to ship in the browser and is safe to commit
# nowhere-near-secret. NEVER put the "Secret key" (formerly service_role) here —
# it grants full database access.

NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxx
